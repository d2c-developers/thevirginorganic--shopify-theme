<div class="max-w-2xl mx-auto px-4">
  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="bg-green-50 p-4 mb-6 rounded">
        <p class="text-green-800">Thank you for your message. We'll get back to you as soon as possible.</p>
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="bg-red-50 p-4 mb-6 rounded">
        <p class="text-red-800">Please correct the following:</p>
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="space-y-6">
      <div>
        <label for="ContactFormName" class="block mb-2">Name</label>
        <input
          type="text"
          name="contact[name]"
          id="ContactFormName"
          class="w-full border p-2"
          value="{{ form.name }}"
          required
        >
      </div>

      <div>
        <label for="ContactFormEmail" class="block mb-2">Email</label>
        <input
          type="email"
          name="contact[email]"
          id="ContactFormEmail"
          class="w-full border p-2"
          value="{{ form.email }}"
          required
        >
      </div>

      <div>
        <label for="ContactFormPhone" class="block mb-2">Phone number</label>
        <input
          type="tel"
          name="contact[phone]"
          id="ContactFormPhone"
          class="w-full border p-2"
          value="{{ form.phone }}"
        >
      </div>

      <div>
        <label for="ContactFormMessage" class="block mb-2">Message</label>
        <textarea
          rows="6"
          name="contact[body]"
          id="ContactFormMessage"
          class="w-full border p-2"
          required
        >{{ form.body }}</textarea>
      </div>

      <div>
        <button type="submit" class="w-full bg-black text-white py-3 px-6 hover:bg-gray-800">Send Message</button>
      </div>
    </div>
  {% endform %}
</div>
