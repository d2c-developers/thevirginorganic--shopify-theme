<script src="{{ 'sections-main-product.min.js' | asset_url }}" async></script>

<div class="min-h-screen bg-white mb-100">
  <div class="w-full px-4 py-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-12 lg:divide-x lg:divide-x-border">
      {% comment %} Product Images {% endcomment %}
      <div class="min-h-[calc(100vh-68px)] flex flex-col justify-center lg:block lg:min-h-[calc(100vh-68px)] lg:h-auto">
        {% comment %} Mobile Product Title and Description {% endcomment %}
        <div class="block lg:hidden text-center max-w-xs mx-auto">
          <div class="text-grey-50 uppercase text-sm font-sans tracking-[0.15em]">
            {{ product.metafields.tvo.tagline }}
          </div>

          {% if product.metafields.tvo.unit_size != blank %}
            <div class="text-dark-grey font-serif italic">
              {{ product.metafields.tvo.unit_size }}
            </div>
          {% endif %}

          <h2
            class="text-4xl font-serif mt-[10px] text-dark-grey"
            style="color: {{ product.metafields.tvo.label_color | default: '#000000' }}"
          >
            {{ product.title }}
          </h2>
          <p class="text-dark-grey mt-4 text-xl">{{ product.description }}</p>
        </div>

        {% comment %} Product Image {% endcomment %}
        <div class="lg:w-full h-full relative grow lg:flex lg:flex-col lg:min-h-[calc(100vh-108px)] lg:h-auto">
          <div id="product-slider" class="swiper h-full w-full lg:h-auto">
            <div class="swiper-wrapper {% if product.images.size > 1 %}pb-8{% else %}pb-0{% endif %} lg:flex lg:flex-col lg:justify-center lg:items-center">
              {% for image in product.images %}
                <div class="swiper-slide h-[calc(100vh-108px)]">
                  <img
                    src="{{ image | image_url: width: 1000 }}"
                    alt="{{ image.alt | default: product.title }}"
                    width="1000"
                    height="1000"
                    class="w-full h-full object-contain lg:w-[initial] mx-auto"
                    loading="lazy"
                  >
                  {% comment %} Only show the CCof icon on the first image for Olive Oil products {% endcomment %}
                  {% if forloop.first and product.type == 'Olive Oil' %}
                    <div class="absolute top-9 left-4 size-24 overflow-hidden sm:top-12 sm:left-12 lg:top-9 lg:left-4">
                      {% render 'icon-ccof', class: 'w-full h-full object-contain' %}
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
            <div class="swiper-pagination--product lg:hidden"></div>
          </div>
        </div>
      </div>

      {% comment %} Product Details {% endcomment %}
      <div class="px-5 mt-4 lg:pr-0 lg:py-10 lg:mt-0">
        <div class="w-full max-w-[350px] mx-auto lg:sticky lg:top-[108px]">
          <div class="hidden lg:block mb-6">
            <div class="flex items-center gap-2 justify-between">
              <div class="text-grey-50 uppercase text-sm font-sans tracking-[0.15em]">
                {{ product.metafields.tvo.tagline }}
              </div>

              {% if product.metafields.tvo.unit_size != blank %}
                <div class="text-dark-grey font-serif italic">
                  {{ product.metafields.tvo.unit_size }}
                </div>
              {% endif %}
            </div>
            <h2
              class="text-4xl font-serif mt-[10px] text-dark-grey"
              style="color: {{ product.metafields.tvo.label_color | default: '#000000' }}"
            >
              {{ product.title }}
            </h2>
            <p class="text-dark-grey mt-4 text-xl">{{ product.description }}</p>
          </div>

          <form class="space-y-6 js-product-form">
            {% comment %} Hidden input for the variant id. Will be updated based on Size selection {% endcomment %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {% comment %} Quantity Selector {% endcomment %}
            <div class="border-b border-border pb-5 flex justify-between items-center">
              <label for="quantity" class="block text-dark-grey italic font-serif">Quantity</label>
              <div class="flex gap-4">
                {% for i in (1..4) %}
                  <div class="flex items-center">
                    <input
                      type="radio"
                      name="quantity"
                      id="quantity-{{ i }}"
                      value="{{ i }}"
                      class="sr-only peer"
                      {% if forloop.first %}
                        checked
                      {% endif %}
                    >
                    <label
                      for="quantity-{{ i }}"
                      class="flex items-center justify-center border-b border-transparent hover:border-b-dark-grey peer-checked:border-b-dark-grey cursor-pointer text-grey-50 peer-checked:text-dark-grey"
                    >
                      {{ i }}
                    </label>
                  </div>
                {% endfor %}
              </div>
            </div>

            {% comment %} Purchase Options {% endcomment %}
            {% if product.type != 'Gift Card' %}
              <div class="space-y-5 border-b border-border pb-5">
                <label for="one-time" class="flex items-center justify-between cursor-pointer">
                  <div class="flex items-center space-x-2">
                    <input
                      type="radio"
                      name="selling_plan"
                      value=""
                      id="one-time"
                      checked
                      class="appearance-none size-5 border border-grey-50 rounded-full checked:before:content-[''] checked:before:absolute checked:before:w-[10px] checked:before:h-[10px] checked:before:bg-dark-grey checked:border-dark-grey checked:before:rounded-full checked:before:top-1/2 checked:before:left-1/2 checked:before:-translate-x-1/2 checked:before:-translate-y-1/2 relative cursor-pointer"
                    >
                    <span class="ml-2 font-serif">One-time purchase</span>
                  </div>
                  <span class="flex items-center gap-1">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <span style="color: {{ product.metafields.tvo.label_color | default: '#C53E12' }}">
                        Save
                        {{
                          product.compare_at_price
                          | minus: product.price
                          | times: 100.0
                          | divided_by: product.compare_at_price
                          | round
                        -}}
                        %
                      </span>
                    {% endif %}
                  </span>
                </label>
                {% if product.selling_plan_groups.size > 0 %}
                  <label for="subscribe" class="flex items-center justify-between cursor-pointer">
                    <div class="flex items-center space-x-2">
                      <input
                        type="radio"
                        name="selling_plan"
                        value="{{ product.selling_plan_groups[0].selling_plans[0].id }}"
                        id="subscribe"
                        class="appearance-none size-5 border border-grey-50 rounded-full checked:before:content-[''] checked:before:absolute checked:before:w-[10px] checked:before:h-[10px] checked:before:bg-dark-grey checked:border-dark-grey checked:before:rounded-full checked:before:top-1/2 checked:before:left-1/2 checked:before:-translate-x-1/2 checked:before:-translate-y-1/2 relative cursor-pointer"
                      >
                      <span class="ml-2 font-serif">Subscribe and save</span>
                    </div>
                    <span class="flex items-center gap-1 font-serif italic">
                      {{ product.price | times: 0.9 | money }}
                      <span style="color: {{ product.metafields.tvo.label_color | default: '#C53E12' }}">Save 10%</span>
                    </span>
                  </label>
                {% endif %}
              </div>
            {% endif %}

            {% comment %} Gift Card Denominations {% endcomment %}
            {% if product.gift_card? and product.variants.size > 1 %}
              <div class="mt-5 space-y-5 border-b border-border pb-5 flex items-start justify-between">
                <p class="block text-dark-grey italic font-serif">Select an amount:</p>
                <div class="space-y-5 flex items-start justify-center flex-col">
                  {% for variant in product.variants %}
                    <label
                      for="variant-{{ variant.id }}"
                      class="flex items-center justify-between cursor-pointer w-full"
                    >
                      <div class="flex items-center space-x-2 justify-between w-full">
                        <input
                          type="radio"
                          name="id"
                          value="{{ variant.id }}"
                          id="variant-{{ variant.id }}"
                          {% if forloop.first %}
                            checked
                          {% endif %}
                          class="appearance-none size-5 border border-grey-50 rounded-full checked:before:content-[''] checked:before:absolute checked:before:w-[10px] checked:before:h-[10px] checked:before:bg-dark-grey checked:border-dark-grey checked:before:rounded-full checked:before:top-1/2 checked:before:left-1/2 checked:before:-translate-x-1/2 checked:before:-translate-y-1/2 relative cursor-pointer"
                        >
                        <span class="font-serif">{{ variant.price | money }}</span>
                      </div>
                    </label>
                  {% endfor %}
                </div>
              </div>
            {% endif %}

            <!-- Frequency Selector for Selling Plans -->
            {% if product.selling_plan_groups.size > 0 %}
              <div class="relative hidden" data-js-selling-plan-selector-container>
                <select
                  data-js-selling-plan-selector
                  name="selling_plan"
                  class="w-full border border-border rounded-sm text-dark-grey uppercase font-sans tracking-[0.15em] text-sm appearance-none p-[14px] cursor-pointer"
                >
                  {% for selling_plan in product.selling_plan_groups[0].selling_plans %}
                    <option value="{{ selling_plan.id }}">
                      {{ selling_plan.name }}
                    </option>
                  {% endfor %}
                </select>
                <div class="absolute right-[14px] top-0 h-full flex items-center justify-center">
                  {% render 'icon-arrow-down' %}
                </div>
              </div>
            {% endif %}

            <!-- Size Selector -->
            {% if product.options contains 'Size' %}
              {% assign size_option = product.options_with_values | where: 'name', 'Size' | first %}
              <div class="relative" data-js-size-selector-container>
                <select
                  data-js-size-selector
                  name="size"
                  class="w-full border border-border rounded-sm text-dark-grey uppercase font-sans tracking-[0.15em] text-sm appearance-none p-[14px] cursor-pointer"
                >
                  {% for size in size_option.values %}
                    <option value="{{ size }}">
                      {{ size }}
                    </option>
                  {% endfor %}
                </select>
                <div class="absolute right-[14px] top-0 h-full flex items-center justify-center">
                  {% render 'icon-arrow-down' %}
                </div>
              </div>
            {% endif %}

            <!-- Add to Cart Button -->
            <button
              type="submit"
              name="add"
              class="w-full bg-dark-grey text-white uppercase font-sans tracking-[0.15em] text-sm p-5"
              {% unless product.available %}
                disabled
              {% endunless %}
              data-ph-capture-attribute-product-name="{{ product.title }}"
              data-ph-capture-attribute-product-price="{{ product.price | divided_by: 100 }}"
            >
              {% if product.available %}
                Add to Cart
              {% else %}
                Sold Out
              {% endif %}
            </button>
          </form>

          <script>
            document.addEventListener('DOMContentLoaded', () => {
              // Get all product variants for lookup based on the selected Size.
              const variants = {{ product.variants | json }};
              const form = document.querySelector('.js-product-form');
              const sellingPlanContainer = document.querySelector('[data-js-selling-plan-selector-container]');
              const oneTimeRadio = document.getElementById('one-time');
              const subscribeRadio = document.getElementById('subscribe');
              const sizeSelector = document.querySelector('[data-js-size-selector]');
              const denominationRadios = document.querySelectorAll('input[name="id"][type="radio"]');

              // The hidden input that holds the variant id.
              const variantInput = form.querySelector('input[name="id"]');

              // Handle radio changes for selling plans.
              if (oneTimeRadio) {
                oneTimeRadio.addEventListener('change', () => {
                  if(sellingPlanContainer) {
                    sellingPlanContainer.classList.add('hidden');
                  }
                });
              }

              if (subscribeRadio) {
                subscribeRadio.addEventListener('change', () => {
                  if(sellingPlanContainer) {
                    sellingPlanContainer.classList.remove('hidden');
                  }
                });
              }

              // Handle changes to the Size selector.
              if (sizeSelector) {
                sizeSelector.addEventListener('change', (e) => {
                  const selectedSize = e.target.value;
                  // Find the variant where the Size (option1) matches the selected value.
                  const selectedVariant = variants.find(variant => variant.option1 === selectedSize);
                  if (selectedVariant) {
                    variantInput.value = selectedVariant.id;
                  }
                });
                // Trigger the change event on load to update the variant id based on default selection.
                sizeSelector.dispatchEvent(new Event('change'));
              }

              // Handle changes to gift card denomination radios
              if (denominationRadios.length > 0) {
                denominationRadios.forEach(radio => {
                  radio.addEventListener('change', (e) => {
                    variantInput.value = e.target.value;
                  });
                });
              }

              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(form);

                // Ensure only one selling_plan value is submitted:
                if (subscribeRadio && subscribeRadio.checked) {
                  const planSelector = document.querySelector('[data-js-selling-plan-selector]');
                  if (planSelector) {
                    formData.set('selling_plan', planSelector.value);
                  }
                } else if (oneTimeRadio?.checked || !oneTimeRadio) {
                  formData.delete('selling_plan');
                }

                console.log('formData values:', Array.from(formData.entries()));
                try {
                  const response = await fetch('/cart/add.js', {
                    method: 'POST',
                    body: formData,
                  });
                  const data = await response.json();
                  console.log('Successfully added product to cart:', data);
                  document.dispatchEvent(new Event('product:added'));
                } catch (error) {
                  console.error('Error adding to cart:', error);
                }
              });
            });
          </script>
        </div>
      </div>
      {% comment %} End Product Details {% endcomment %}
    </div>
    <div class="border-t border-border mt-[50px] lg:mt-5"></div>
  </div>

  {% comment %} Long Description {% endcomment %}
  <div class="px-5 text-dark-grey font-medium font-serif text-[32px] lg:text-[36px] leading-tight tracking-[0.01em]">
    {{ product.metafields.tvo.varietal_long_description | metafield_tag }}
  </div>
</div>

{% render 'product-specifications' %}
{% render 'product-polyphenol-chart' %}

{% schema %}
{
  "name": "Main Product",
  "class": "mb-100 lg:mb-52"
}
{% endschema %}
