<style>
  /* Hero animation styles */
  {% comment %} @media screen and (min-width: 1px) { {% endcomment %}
    .site-header {
      opacity: 0;
      animation: fadeIn 1.33s ease forwards 2s;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      height: 100%;
      width: 100%;
    }

    .hero-text {
      opacity: 0;
      animation: fadeIn 1.33s ease forwards 1.33s;
    }

    .product-image {
      opacity: 0;
      animation: fadeIn 1.33s ease-in-out forwards 2s;
    }

    .cta-text {
      opacity: 0;
      animation: fadeIn 1.33s ease forwards 2s;
    }

    .hero-content .ui-button svg {
      opacity: 0;
      animation: fadeIn 1.33s ease forwards 3.33s, bounceRight 1.33s ease-in-out forwards 4.67s;
    }

    @keyframes bounceRight {
      0% {
        transform: translateX(0px);
      }
      50% {
        transform: translateX(3px);
      }
      75% {
        transform: translateX(-2px);
      }
      80% {
        transform: translateX(2px);
      }
      90% {
        transform: translateX(0);
      }
      95% {
        transform: translateX(1px);
      }
      100% {
        transform: translateX(0px);
      }
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes shrinkFont {
      to {
        transform: translate(-50%, -50%) scale(2.5);
        opacity: 0;
      }
    }
  {% comment %} } {% endcomment %}
</style>

<div class="hero-content pt-[50px] text-center bg-white text-dark-grey relative z-[100] max-h-[calc(100vh - 64px)] min-h-screen lg:min-h-screen flex flex-col lg:flex-row lg:items-center lg:justify-between lg:text-white max-h-screen lg:mb-[90px] lg:!mt-0 lg:pt-0 lg:bg-transparent lg:max-h-none">
  {% comment %} H1 {% endcomment %}
  <div class="w-full lg:flex lg:justify-start xl:w-1/3 pt-[50px] lg:p-8 text-center z-10 bg-white lg:bg-transparent">
    {% if section.settings.heading != blank %}
      <div class="text-4xl hero-text xl:mx-auto">
        {{ section.settings.heading }}
      </div>
    {% endif %}
  </div>

  {% comment %} Text Content {% endcomment %}
  <div class="z-20 sm:min-w-[400px] flex items-end justify-end flex-col xl:w-1/3 p-4 lg:p-8 text-center lg:order-3 bg-white lg:bg-transparent cta-text">
    {% if section.settings.text != blank %}
      <div class="max-w-[400px] mx-auto text-[22px] font-serif leading-tight">{{ section.settings.text }}</div>
    {% endif %}
    {% if section.settings.button_text != blank %}
      <div
        class="mt-10 hidden lg:static lg:flex lg:bg-transparent lg:text-white lg:justify-center lg:mx-auto"
      >
        {%
          render 'ui-button',
          button_text: section.settings.button_text,
          href: section.settings.button_link | default: '/collections/shop-all',
          style: 'faded',
          type: 'link'
        %}
      </div>
      <a
        data-js-cta-button
        href="{{ section.settings.button_link | default: '/collections/shop-all' }}"
        class="z-50 fixed left-5 right-5 bottom-5 bg-white text-dark-grey border border-dark-grey flex justify-between lg:!hidden"
      >
        <span class="font-sans text-sm uppercase tracking-[0.15em] block p-5">Shop Now</span>
        <span class="p-5 border-l border-grey-25 flex items-center justify-center">
          {% render 'icon-arrow-right' %}
        </span>
      </a>
    {% endif %}
  </div>

  {% comment %} Background Image {% endcomment %}
  {% if section.settings.background_image != blank %}
    <div class="bg-image absolute bottom-0 left-0 lg:inset-0 w-full aspect-square lg:aspect-auto lg:h-full">
      <picture>
        <source media="(max-width: 989px)" srcset="{{ section.settings.background_image | image_url: width: 800 }}">
        {{
          section.settings.background_image
          | image_url: width: 2000
          | image_tag: width: 1600, height: 900, alt: '', class: 'w-full h-full object-cover', preload: true
        }}
      </picture>
    </div>
  {% endif %}

  {% comment %} Bottle Render {% endcomment %}
  {% if section.settings.bottle_image != blank %}
    <div class="product-image grow relative z-10 lg:absolute lg:left-1/2 lg:-translate-x-1/2 w-full lg:min-w-[33%] lg:h-[calc(100%)] lg:min-h-[calc(100%)] lg:order-2 lg:bottom-[-90px]">
      <picture>
        <source media="(min-width: 990px)" srcset="{{ section.settings.bottle_image | image_url: width: 1600 }}">
        {{
          section.settings.bottle_image
          | image_url: width: 600
          | image_tag:
            width: 400,
            height: 500,
            alt: '',
            class: 'absolute object-contain w-full h-full z-20',
            preload: true
        }}
      </picture>
      <div
        class="before:bg-white before:absolute before:top-0 before:left-0 before:w-full before:h-1/4 before:z-10 before:lg:hidden"
      ></div>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ctaButton = document.querySelector('[data-js-cta-button]');
    const footer = document.querySelector('footer');

    if (ctaButton && window.innerWidth < 1280) {
      // Hide button when footer is in view
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            ctaButton.style.display = 'none';
          } else {
            ctaButton.style.display = 'flex';
          }
        });
      });

      if (footer) {
        observer.observe(footer);
      }
    }
  });
</script>

{% schema %}
{
  "name": "Homepage Hero",
  "class": "hero",
  "settings": [
    {
      "type": "header",
      "content": "Text Content Settings"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Compromise <em>Nothing</em></p>"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Subtext",
      "default": "<p>Our belief in world-class olive oils starts from the ground up.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Background Image Settings"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Bottle Render Settings"
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Bottle image"
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}
