<style>
  /* Hero animation styles */
  @media screen and (min-width: 1280px) {
    .site-header {
      opacity: 0;
      animation: fadeIn 2s ease forwards 3s;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      height: 100%;
      width: 100%;
    }

    .hero-text {
      opacity: 0;
      animation: fadeIn 2s ease forwards 2s;
    }

    .product-image {
      opacity: 0;
      animation: fadeIn 2s ease-in-out forwards 3s;
    }

    .cta-text {
      opacity: 0;
      animation: fadeIn 2s ease forwards 3s;
    }

    .hero-content .ui-button svg {
      opacity: 0;
      animation: fadeIn 2s ease forwards 5s, bounceRight 2s ease-in-out forwards 7s;
    }

    @keyframes bounceRight {
      0% {
        transform: translateX(0px);
      }
      50% {
        transform: translateX(3px);
      }
      75% {
        transform: translateX(-2px);
      }
      80% {
        transform: translateX(2px);
      }
      90% {
        transform: translateX(0);
      }
      95% {
        transform: translateX(1px);
      }
      100% {
        transform: translateX(0px);
      }
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes shrinkFont {
      to {
        transform: translate(-50%, -50%) scale(2.5);
        opacity: 0;
      }
    }
  }
</style>

<div class="hero-content pt-[50px] text-center bg-white text-dark-grey relative max-h-[calc(100vh - 64px)] min-h-screen xl:min-h-screen flex flex-col xl:flex-row xl:items-center xl:justify-between  xl:text-white max-h-screen xl:mb-[90px] xl:!mt-0 xl:pt-0 xl:bg-transparent xl:max-h-none">
  {% comment %} H1 {% endcomment %}
  <div class="w-full xl:w-1/3 pt-[50px] xl:p-8 text-center z-10 bg-white xl:bg-transparent">
    {% if section.settings.heading != blank %}
      <h1 class="text-4xl hero-text">
        {{ section.settings.heading }}
      </h1>
    {% endif %}
  </div>

  {% comment %} Text Content {% endcomment %}
  <div class="relative z-20 w-full xl:w-1/3 p-4 xl:p-8 text-center xl:order-3 bg-white xl:bg-transparent cta-text">
    {% if section.settings.text != blank %}
      <div class="max-w-[400px] mx-auto text-[22px] font-serif leading-tight">{{ section.settings.text }}</div>
    {% endif %}
    {% if section.settings.button_text != blank %}
      <div
        class="justify-center mt-10 hidden  xl:static xl:flex xl:bg-transparent xl:text-white"
      >
        {%
          render 'ui-button',
          button_text: section.settings.button_text,
          href: section.settings.button_link | default: '/collections/shop-all',
          style: 'faded',
          type: 'link'
        %}
      </div>
      <a
        data-js-cta-button
        href="{{ section.settings.button_link | default: '/collections/shop-all' }}"
        class="z-50 fixed left-5 right-5 bottom-5 bg-white text-dark-grey border border-dark-grey flex justify-between xl:!hidden"
      >
        <span class="font-sans text-sm uppercase tracking-[0.15em] block p-5">Shop Now</span>
        <span class="p-5 border-l border-grey-25 flex items-center justify-center">
          {% render 'icon-arrow-right' %}
        </span>
      </a>
    {% endif %}
  </div>

  {% comment %} Background Image {% endcomment %}
  {% if section.settings.background_image != blank %}
    <div class="bg-image absolute bottom-0 left-0 {% if settings.enable_mobile %}mt-[25vh] xl:mt-0{% endif %} xl:inset-0 w-full aspect-square xl:aspect-auto xl:h-full">
      <img
        src="{{ section.settings.background_image | image_url: width: 2000 }}"
        width="2000"
        height="{{ 2000 | divided_by: section.settings.background_image.aspect_ratio | round }}"
        alt="{{ section.settings.background_image.alt | default: section.settings.heading }}"
        class="w-full h-full object-cover"
      >
    </div>
  {% endif %}

  {% comment %} Bottle Render {% endcomment %}
  {% if section.settings.bottle_image != blank %}
    <div class="product-image grow relative z-10 xl:absolute xl:left-1/2 xl:-translate-x-1/2 xl:w-1/3 xl:h-[calc(100%)] xl:order-2 xl:bottom-[-90px]">
      <img
        src="{{ section.settings.bottle_image | image_url: width: 800 }}"
        {% comment %} @TODO: make this correct {% endcomment %}
        width="800"
        height="{{ 800 | divided_by: section.settings.bottle_image.aspect_ratio | round }}"
        alt="{{ section.settings.bottle_image.alt | default: 'Product bottle' }}"
        class="absolute object-contain w-full h-full z-20"
      >
      <div
        class="before:bg-white before:absolute before:top-0 before:left-0 before:w-full before:h-1/4 before:z-10 before:xl:hidden"
      ></div>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ctaButton = document.querySelector('[data-js-cta-button]');
    const footer = document.querySelector('footer');

    if (ctaButton && window.innerWidth < 1280) {
      // Hide button when footer is in view
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            ctaButton.style.display = 'none';
          } else {
            ctaButton.style.display = 'flex';
          }
        });
      });

      if (footer) {
        observer.observe(footer);
      }
    }
  });
</script>

{% schema %}
{
  "name": "Homepage Hero",
  "class": "hero",
  "settings": [
    {
      "type": "header",
      "content": "Text Content Settings"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Compromise <em>Nothing</em></p>"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Subtext",
      "default": "<p>Our belief in world-class olive oils starts from the ground up.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Background Image Settings"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Bottle Render Settings"
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Bottle image"
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}
