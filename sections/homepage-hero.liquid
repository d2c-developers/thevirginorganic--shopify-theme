<div class="mt-[64px] text-center bg-white text-black relative min-h-screen flex flex-col xl:flex-row xl:items-center xl:justify-between  xl:text-white max-h-screen xl:mb-[90px] xl:!mt-0 xl:bg-transparent">
  {% comment %} H1 {% endcomment %}
  <div class="relative w-full xl:w-1/3 pt-[50px] xl:p-8 text-center z-10 bg-white xl:bg-transparent">
    {% if section.settings.heading != blank %}
      <h1 class="font-heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}
  </div>

  {% comment %} Text Content {% endcomment %}
  <div class="relative w-full xl:w-1/3 p-4 xl:p-8 text-center xl:order-3 z-10 bg-white xl:bg-transparent">
    {% if section.settings.text != blank %}
      <div class="max-w-[400px] mx-auto text-[22px] font-serif leading-tight">{{ section.settings.text }}</div>
    {% endif %}
    {% if section.settings.button_text != blank %}
      <div class="justify-center mt-4 hidden xl:flex">
        {% render 'ui-button',
          button_text: section.settings.button_text,
          href: routes.all_products_collection_url,
          style: 'faded'
        %}
      </div>
    {% endif %}
  </div>

  {% comment %} Background Image {% endcomment %}
  {% if section.settings.background_image != blank %}
    <div class="absolute bottom-0 left-0 {% if settings.enable_mobile %}mt-[25vh] xl:mt-0{% endif %} xl:inset-0 w-full aspect-square xl:aspect-auto xl:h-full">
      <img
        src="{{ section.settings.background_image | image_url: width: 2000 }}"
        width="2000"
        height="{{ 2000 | divided_by: section.settings.background_image.aspect_ratio | round }}"
        alt="{{ section.settings.background_image.alt | default: section.settings.heading }}"
        class="w-full h-full object-cover"
      >
    </div>
  {% endif %}

  {% comment %} Bottle Render {% endcomment %}
  {% if section.settings.bottle_image != blank %}
    <div class="grow relative z-10 xl:absolute xl:left-1/2 xl:-translate-x-1/2 xl:w-1/3 xl:h-[calc(100%)] xl:order-2 xl:bottom-[-90px]">
      <img
        src="{{ section.settings.bottle_image | image_url: width: 800 }}"
        {% comment %} @TODO: make this correct {% endcomment %}
        width="800"
        height="{{ 800 | divided_by: section.settings.bottle_image.aspect_ratio | round }}"
        alt="{{ section.settings.bottle_image.alt | default: 'Product bottle' }}"
        class="absolute object-contain w-full h-full z-20"
      >
      <div
        class="before:bg-white before:absolute before:top-0 before:left-0 before:w-full before:h-1/4 before:z-10 before:xl:hidden"
      ></div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Homepage Hero",
  "settings": [
    {
      "type": "header",
      "content": "Text Content Settings"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Compromise <br/> Nothing</p>"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Subtext",
      "default": "<p>Our belief in world-class olive oils starts from the ground up.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "header",
      "content": "Background Image Settings"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Bottle Render Settings"
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Bottle image"
    }
  ],
  "presets": [
    {
      "name": "Homepage Hero"
    }
  ]
}
{% endschema %}
