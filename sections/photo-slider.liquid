<div class="flex flex-col xl:flex-row-reverse ">
  {% comment %} Image Slider {% endcomment %}
  <div class="w-full xl:w-2/3 ">
    <div class="swiper" id="photo-slider--images">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <div class="swiper-slide mr-5 border-r pr-5 border-gray-200">
              <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.image.alt }}">
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  {% comment %} Text Slider {% endcomment %}
  <div class="w-full xl:w-1/3 flex flex-col justify-between items-start h-full ">
    <div class="text-center">
      <div class="mt-5">{{ section.settings.section_body }}asdfasdfasda</div>
    </div>
    <div class="swiper h-full w-full" id="photo-slider--text">
      <!-- Additional required wrapper -->
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <div class="swiper-slide">
              <h2>{{ block.settings.heading }}</h2>
              <p>{{ block.settings.body }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <!-- If we need pagination -->
      <div class="swiper-pagination"></div>

      <!-- If we need navigation buttons -->
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Photo Slider",
  "class": "my-100",
  "settings": [
    {
      "type": "richtext",
      "id": "section_body",
      "label": "Section Body",
      "default": "<p>This is a section body that will be displayed in the left content area.</p>"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Photo Slider"
    }
  ]
}
{% endschema %}
