    <p class="font-heading">"</p>
    <p class="font-heading">{{ section.settings.quote }}</p>
  </div>
  <p class="text-sm uppercase font-sans tracking-[.15em] text-coratina-green">{{ section.settings.quote_author }}</p>
</div>
{% schema %}
{
  "name": "Big Quote",
  "class": "my-100",
