<div class="space-y-50 max-w-4xl mx-auto">
  <div class="text-center">
    <div class="flex flex-col items-center justify-center space-y-5">
      {% if section.settings.eyebrow != blank %}
        <div class="text-sm uppercase font-sans tracking-[0.15em] text-grey-50">{{ section.settings.eyebrow }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="font-heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% render 'icon-triple-star-aesthetic' %}
    </div>
  </div>

  <div class="swiper relative pb-[80px] xl:pb-0" id="blog-posts-slider">
    <div class="swiper-wrapper">
      {% assign articles = section.blocks | where: 'type', 'article' %}
      {% if articles.size == 0 %}
        {% assign articles = blog.articles %}
      {% endif %}
      {% for block in section.blocks %}
        {% if block.type == 'article' %}
          {% assign article = block.settings.article %}
          <a
            href="{{ article.url }}"
            class="swiper-slide block pr-5 border-r mr-5 border-gray-200 {% if forloop.last %}border-r-transparent{% endif %}"
          >
            <div class="aspect-[28/23] relative mb-5">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt }}"
                  class="absolute inset-0 w-full h-full object-cover"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                  loading="lazy"
                >
              {% else %}
                <div class="absolute inset-0 bg-gray-100"></div>
              {% endif %}
            </div>
            <div class="space-y-[10px] text-center max-w-[285px] mx-auto">
              <p class="italic font-serif text-grey-50">{{ article.published_at | date: '%B %d, %Y' }}</p>
              <h3 class="text-sm uppercase font-sans tracking-[0.15em]">{{ article.title }}</h3>
              <p class="font-serif !italic">
                {% if article.excerpt != blank %}
                  {{ article.excerpt | strip_html | truncatewords: 20 }}
                {% else %}
                  {{ article.content | strip_html | truncatewords: 20 }}
                {% endif %}
              </p>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
    <div class="swiper-pagination--blog"></div>
  </div>

  {% if section.settings.button_text != blank and section.settings.button_link != blank %}
    <div class="w-full flex justify-center items-center px-5">
      <div class="mx-auto text-center xl:text-left">
        {% render 'ui-button', type: 'link', button_text: section.settings.button_text, href: section.settings.button_link | default: '/blogs/blog' %}
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Featured Blog Posts",
  "class": "my-100",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Blog Posts"
    }
  ]
}
{% endschema %}
