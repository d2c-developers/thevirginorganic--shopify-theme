<div class="p-5 font-medium font-serif text-[32px] xl:text-[36px] leading-tight {{ section.settings.custom_class }}">
  {{ section.settings.text }}
</div>

{% schema %}
{
  "name": "Large Heading Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text Content",
      "default": "<p>Enter your text here - choose the correct html / heading tag for your use case. Ask JM if unsure but don't block your goal.</p>"
    }
  ],
  "presets": [
    {
      "name": "Large Heading Text"
    }
  ]
}
{% endschema %}
