<style></style>
<article class="space-y-50 px-5">
  <div class="border-b border-border space-y-50 pb-50">
    <header class="px-5 text-center space-y-[30px] xl:space-y-[40px]">
      {% if page.metafields.tvo.eyebrow_text != blank %}
        <div class="font-serif text-[#4c4c46] italic">{{ page.metafields.tvo.eyebrow_text }}</div>
      {% endif %}
      <h1 class="font-heading max-w-sm mx-auto">{{ page.title }}</h1>
    </header>

    {% if page.metafields.tvo.featured_image %}
      <div class="w-full aspect-square relative xl:aspect-video xl:px-5">
        <img
          src="{{ page.metafields.tvo.featured_image | image_url: width: 1200 }}"
          alt="{{ page.metafields.tvo.featured_image.alt }}"
          class="absolute inset-0 w-full h-full object-cover"
          width="{{ page.metafields.tvo.featured_image.width }}"
          height="{{ page.metafields.tvo.featured_image.height }}"
          loading="lazy"
        >
      </div>
    {% endif %}
    <div class="font-serif prose mx-auto">
      {{ page.content }}
    </div>
  </div>

  <div class="px-5 space-y-50">
    {% assign stockists = metaobjects.stockist.values %}
    {% if stockists != blank %}
      <div class="grid grid-cols-1 xl:grid-cols-2 gap-10 pb-50 border-b border-border">
        <h2 class="font-sans text-sm tracking-[0.15em] uppercase">Stockists</h2>
        <div class="space-y-10">
          <div class="font-serif text-lg text-dark-grey max-w-xl">
            The Virgin Organic is primarily an online business. However, we have carefully selected a handful of retail
            accounts in the United States. Currently, these locations are;
          </div>
          {% for stockist in stockists %}
            <div class="">
              <p class="font-serif text-[22px] text-[#4c4c46]">{{ stockist.name.value }}</p>
              <p class="text-dark-grey font-sans text-sm tracking-[0.15em] uppercase">{{ stockist.address.value }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% comment %} Address & Hours {% endcomment %}
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-10 pb-50 border-b border-border">
      <h2 class="font-sans text-sm tracking-[0.15em] uppercase">Company Info</h2>
      <div class="space-y-10">
        <div>
          <h3 class="text-sm text-dark-grey font-sans tracking-[0.15em] uppercase">Details</h3>
          <div class="font-serif text-lg text-[#4c4c46] max-w-xl">
            The Virgin Organic <br>
            TVO / LLC <br>
            San Diego, CA 92104 <br>
            415-623-6923
          </div>
        </div>
        <div>
          <p class="text-dark-grey font-sans text-sm tracking-[0.15em] uppercase ">Hours of Operation</p>
          <p class="font-serif text-lg text-[#4c4c46]">
            Monday — Friday 9:00am -5:00pm PST <br>
            Closed on most US holidays
          </p>
        </div>
      </div>
    </div>

    {% comment %} Contact {% endcomment %}
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-10 pt-50">
      <h2 class="font-sans text-sm tracking-[0.15em] uppercase">Contact</h2>
      <div class="font-serif space-y-5">
        {% if shop.email != blank %}
          <div>
            <h3 class="text-sm text-dark-grey font-sans tracking-[0.15em] uppercase">Email</h3>
            <a href="mailto:{{ shop.email }}" class="font-serif text-[22px] text-[#4c4c46] max-w-xl underline">
              Email Us
            </a>
          </div>
        {% endif %}
        <div>
          <h3 class="text-sm text-dark-grey font-sans tracking-[0.15em] uppercase">Social</h3>
          {% if settings.social_instagram_link != blank %}
            <a
              href="{{ settings.social_instagram_link }}"
              class="block font-serif text-[22px] text-[#4c4c46] max-w-xl underline"
            >
              Instagram
            </a>
          {% endif %}
          {% if settings.social_youtube_link != blank %}
            <a
              href="{{ settings.social_youtube_link }}"
              class="block font-serif text-[22px] text-[#4c4c46] max-w-xl underline"
            >
              YouTube
            </a>
          {% endif %}
          {% if settings.social_x_link != blank %}
            <a
              href="{{ settings.social_x_link }}"
              class="block font-serif text-[22px] text-[#4c4c46] max-w-xl underline"
            >
              X
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</article>

<script type="application/ld+json">
  {{ page | structured_data }}
</script>

{% schema %}
{
  "name": "Main Article",
  "class": "my-50 xl:mb-100 xl:pb-100",
  "settings": []
}
{% endschema %}
