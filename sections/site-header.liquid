<header class="site-header fixed z-50 bg-white top-0 left-0 right-0 text-dark-grey {% if template == 'index' %}lg:text-white lg:bg-transparent{% endif %}">
  {% if section.blocks.size > 0 %}
    {% assign bar_classes = "text-center bg-[#DF4B2A] text-white py-2 font-sans tracking-none uppercase text-sm" %}
    <div class="{{ bar_classes }}">
      <span
        class="announcement-bar-text transition-opacity duration-500 ease-in-out"
        data-messages='[{% for block in section.blocks %}"{{ block.settings.message | escape }}"{% unless forloop.last %},{% endunless %}{% endfor %}]'
      >
        {{ section.blocks.first.settings.message }}
      </span>
    </div>
  {% endif %}
  <div class="relative flex items-center justify-between w-full font-serif p-5 lg:text-lg">
    {% comment %} Left List {% endcomment %}
    <div>
      {% comment %} Desktop List{% endcomment %}
      <nav class="hidden lg:flex lg:items-center lg:gap-4">
        <ul class="flex items-center gap-1">
          {% for item in linklists['shop-menu'].links %}
            <li>
              <a href="{{ item.url }}" class="inline-block">
                {{- item.title -}}
              </a>
              <span>—</span>
              {% if item.links.size > 0 %}
                {% for child in item.links %}
                  <a href="{{ child.url }}" class="inline-block italic">
                    {{- child.title -}}
                    {%- unless forloop.last %},{% endunless -%}
                  </a>
                {% endfor %}
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
      {% comment %} Mobile Menu Button {% endcomment %}
      <button
        type="button"
        class="lg:hidden text-dark-grey flex items-center justify-center relative after:absolute after:bottom-0 after:bg-dark-grey after:w-full after:h-px after:z-10 js-menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        Menu
      </button>
    </div>
  
    {% comment %} Center Logo {% endcomment %}
    <div class="site-header-logo absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2 max-w-60 lg:max-w-80">
      {% if template == 'index' %}
        <h1>
          <a href="{{ routes.root_url }}" class="block">
            <span class="sr-only">The Virgin Organic</span>
            {% render 'site-logo' %}
          </a>
        </h1>
      {% else %}
        <a href="{{ routes.root_url }}" class="block">
          <span class="sr-only">The Virgin Organic</span>
          {% render 'site-logo' %}
        </a>
      {% endif %}
    </div>
  
    {% comment %} Right List {% endcomment %}
    <nav class="flex items-center gap-5">
      <ul class="hidden xl:flex xl:items-center xl:gap-1">
        {% for item in linklists['learn-menu'].links %}
          <li>
            <a href="{{ item.url }}" class="inline-block">
              {{- item.title -}}
            </a>
            <span>—</span>
            {% if item.links.size > 0 %}
              {% for child in item.links %}
                <a href="{{ child.url }}" class="inline-block italic">
                  {{- child.title -}}
                  {%- unless forloop.last %},{% endunless -%}
                </a>
              {% endfor %}
            {% endif %}
          </li>
        {% endfor %}
      </ul>
      <button
        type="button"
        class="inline-block"
        aria-label="Open cart"
        onclick="document.dispatchEvent(new Event('open:cart'));"
      >
        Cart
        <span data-js-cart-count>
          {%- if cart.item_count > 0 %} ({{ cart.item_count }}){% endif -%}
        </span>
      </button>
    </nav>
  </div>
</header>

{% comment %} Mobile Menu {% endcomment %}
<div class="fixed inset-0 bg-white z-40 -translate-x-full transition-transform duration-200 ease-in-out lg:hidden js-mobile-menu">
  <div class="h-full pt-[72px] flex flex-col items-center justify-center gap-10">
    <nav class="text-center">
      <ul class="flex flex-col items-center gap-10">
        {% for item in linklists['shop-menu'].links %}
          <li>
            <a href="{{ item.url }}" class="inline-block mb-5 text-grey-50 italic">
              {{- item.title -}}
            </a>
            {% if item.links.size > 0 %}
              <div class="mt-2 font-heading flex flex-col gap-px">
                {% for child in item.links %}
                  <a href="{{ child.url }}" class="inline-block">
                    {{- child.title -}}
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
        {% for item in linklists['learn-menu'].links %}
          <li>
            <a href="{{ item.url }}" class="inline-block mb-5 text-grey-50 italic">
              {{- item.title -}}
            </a>
            {% if item.links.size > 0 %}
              <div class="mt-2 font-heading flex flex-col gap-px">
                {% for child in item.links %}
                  <a href="{{ child.url }}" class="inline-block">
                    {{- child.title -}}
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
    <div class="max-w-60">
      {% render 'site-logo--secondary' %}
    </div>
  </div>
</div>

<script>
  // Announcement Bar Fade Animation
  document.addEventListener('DOMContentLoaded', () => {
    const announcementBarText = document.querySelector('.announcement-bar-text');
    
    if (announcementBarText) {
      const messagesData = announcementBarText.getAttribute('data-messages');
      
      if (messagesData) {
        const messages = JSON.parse(messagesData);
        
        if (messages.length > 1) {
          let currentIndex = 0;
          
          // Rotate through messages
          setInterval(() => {
            // Fade out
            announcementBarText.style.opacity = '0';
            
            setTimeout(() => {
              // Move to next message
              currentIndex = (currentIndex + 1) % messages.length;
              
              // Update text content
              announcementBarText.textContent = messages[currentIndex];
              
              // Fade in
              announcementBarText.style.opacity = '1';
            }, 250); // Half of transition duration
          }, 5000); // Change message every 5 seconds
        }
      }
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    setTimeout(() => {
      if (urlParams.has('cart') && urlParams.get('cart') === 'open') {
        document.dispatchEvent(new Event('open:cart'));
      }
      window.history.replaceState({}, document.title, window.location.pathname);
    }, 500);
 });

  {% if template == 'index' %}
    document.addEventListener('DOMContentLoaded', () => {
      const header = document.querySelector('header');
      header.classList.add('transition-colors');
      header.classList.add('duration-200');

      window.addEventListener('scroll', () => {
        if (window.scrollY > 100) {
          header.classList.remove('lg:bg-transparent', 'lg:text-white');
          header.classList.add('lg:bg-white', 'lg:text-dark-grey');
        } else {
          header.classList.add('bg-white', 'text-dark-grey', 'lg:bg-transparent', 'lg:text-white');
          header.classList.remove('lg:bg-white', 'lg:text-dark-grey');
        }
      });
    });
  {% endif %}

  // Mobile menu functionality
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.querySelector('.js-menu-toggle');
    const mobileMenu = document.querySelector('.js-mobile-menu');
    const body = document.body;

    menuToggle.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', !isExpanded);
      mobileMenu.style.transform = isExpanded ? 'translateX(-100%)' : 'translateX(0)';
      menuToggle.textContent = isExpanded ? 'Menu' : 'Close';

      if (isExpanded) {
        body.style.removeProperty('overflow');
      } else {
        body.style.overflow = 'hidden';
      }
    });
  });

  // Cart Count
  document.addEventListener('cart:updated', (event) => {
    const cart = event.detail;
    const cartCount = document.querySelector('[data-js-cart-count]');

    if (cart && cart.item_count > 0) {
      cartCount.textContent = `(${cart.item_count})`;
    } else {
      cartCount.textContent = '';
    }
  });
</script>

{% schema %}
{
  "name": "Site Header",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "paragraph",
      "content": "Add announcement messages using the blocks below. Multiple messages will automatically fade in and out."
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement Message",
      "settings": [
        {
          "type": "html",
          "id": "message",
          "label": "Message",
          "default": "Free Shipping on Orders Over $98"
        }
      ]
    }
  ]
}
{% endschema %}
