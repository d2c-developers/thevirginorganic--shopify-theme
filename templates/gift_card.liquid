{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {% if settings.favicon_url %}
      <link rel="icon" href="{{ settings.favicon_url | image_url: width: 32, height: 32 }}" type="image/png">
    {% endif %}

    <title>
      {{ gift_card.balance | money_without_trailing_zeros | strip_html }}
      Gift Card -
      {{ shop.name }}
    </title>

    <meta name="description" content="Use this gift card to purchase items at {{ shop.name }}">

    {{ content_for_header }}

    {% render 'site-font-faces' %}
    {% render 'site-local-styles' %}
  </head>

  <body class="font-serif text-dark-grey bg-white ">
    <div class="min-h-screen flex flex-col items-center justify-center px-5 py-100">
      {% section 'site-header' %}

      <div class="flex flex-col items-center justify-center grow text-center w-full max-w-3xl mx-auto">
        <div class="px-5 text-center space-y-[50px]">
          {% if page.metafields.tvo.eyebrow_text != blank %}
            <div class="font-serif text-grey-50 italic">{{ page.metafields.tvo.eyebrow_text }}</div>
          {% endif %}
          <h1 class="font-heading max-w-md mx-auto">Gift Card Balance</h1>
          <div class="space-y-2">
            <p class="font-serif text-4xl text-dark-grey">
              {% if settings.currency_code_enabled %}
                {{ gift_card.balance | money_with_currency }}
              {% else %}
                {{ gift_card.balance | money }}
              {% endif %}
            </p>

            {%- if gift_card.enabled == false or gift_card.expired -%}
              <p class="uppercase font-sans text-sm tracking-[0.15em] text-picual-red">This gift card has expired</p>
            {%- endif -%}

            {% if gift_card.expires_on %}
              {%- assign gift_card_expiration_date = gift_card.expires_on | date: '%B %e, %Y' -%}
              <p class="italic">Expires on {{ gift_card_expiration_date }}</p>
            {% endif %}
          </div>
          <div>
            <h2 class="font-serif italic text-2xl">How to Redeem</h2>
            <p class="text-[22px]">Use the code below at checkout</p>
          </div>
        </div>

        <div class="mt-10"></div>

        <div class="border-y border-grey-400 py-5 mb-10 w-full">
          <p id="gift-card-code" class="font-serif text-2xl">{{ gift_card.code | format_code }}</p>
          <div
            class="gift-card__qr-code flex justify-center mb-5"
            data-identifier="{{ gift_card.qr_identifier }}"
          ></div>

          {%- if gift_card.pass_url -%}
            <a href="{{ gift_card.pass_url }}" class="inline-block no-print mb-5">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                width="120"
                height="40"
                alt="Add to Apple Wallet"
                loading="lazy"
              >
            </a>
          {%- endif -%}

          <div class="flex justify-center">
            {% render 'ui-button', button_text: 'Copy code', type: 'button', class_names: 'gift-card__copy-button' %}
          </div>
        </div>

        <div class="no-print flex flex-col items-center gap-5">
          <span class="gift-card__copy-success text-coratina-green" role="status"></span>
          <template>
            <span class="svg-wrapper">
              {{- 'icon-success.svg' | inline_asset_content -}}
            </span>
            Code copied to clipboard!
          </template>
        </div>
      </div>

      {% section 'site-footer' %}
    </div>
    {% render 'site-local-scripts' %}
  </body>
</html>

<script>
  var string = { qrImageAlt: 'QR code for gift card' };
  document.addEventListener('DOMContentLoaded', function () {
    new QRCode(document.querySelector('.gift-card__qr-code'), {
      text: document.querySelector('.gift-card__qr-code').dataset.identifier,
      width: 120,
      height: 120,
      imageAltText: string.qrImageAlt,
    });
  });

  var template = document.getElementsByTagName('template')[0];
  var clonedTemplate = template.content.cloneNode(true);
  var isMessageDisplayed = false;

  document.querySelector('.gift-card__copy-button').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('gift-card-code').innerText).then(function () {
      if (!isMessageDisplayed) {
        document.querySelector('.gift-card__copy-success').appendChild(clonedTemplate);
        isMessageDisplayed = true;
      }
    });
  });
</script>
