{% comment %} Count available metafields to determine layout {% endcomment %}
{% assign available_fields = 0 %}
{% if product.metafields.tvo.harvest != blank %}
  {% assign available_fields = available_fields | plus: 1 %}
{% endif %}
{% if product.metafields.tvo.intensity != blank %}
  {% assign available_fields = available_fields | plus: 1 %}
{% endif %}
{% if product.metafields.tvo.polyhenial_count != blank %}
  {% assign available_fields = available_fields | plus: 1 %}
{% endif %}

{% comment %} Set grid columns based on available fields {% endcomment %}
{% assign grid_cols = 'lg:grid-cols-1' %}
{% if available_fields == 2 %}
  {% assign grid_cols = 'lg:grid-cols-2' %}
{% elsif available_fields == 3 %}
  {% assign grid_cols = 'lg:grid-cols-3' %}
{% endif %}

<div class="my-100 max-w-4xl mx-auto grid grid-cols-1 {{ grid_cols }} gap-y-50 lg:gap-4">
  {% assign field_index = 0 %}
  
  {% if product.metafields.tvo.harvest != blank %}
    {% assign field_index = field_index | plus: 1 %}
    <div class="flex flex-col items-center justify-start gap-5 pb-[10px] text-center{% if available_fields > 1 and field_index < available_fields %} border-r border-[#4C4C46]/25{% endif %}">
      <span class="text-dark-grey uppercase font-sans tracking-[0.15em] text-sm">Harvest</span>
      <span class="font-serif italic text-grey-50">{{ product.metafields.tvo.harvest }}</span>
    </div>
  {% endif %}

  {% if product.metafields.tvo.intensity != blank %}
    {% assign field_index = field_index | plus: 1 %}
    <div class="flex flex-col items-center justify-start gap-5 pb-[10px] text-center{% if available_fields == 3 and field_index < available_fields %} border-r border-[#4C4C46]/25{% endif %}">
      <span class="text-dark-grey uppercase font-sans tracking-[0.15em] text-sm">Intensity</span>
      <span class="max-w-[220px] font-serif italic text-grey-50">
        {{ product.metafields.tvo.intensity | newline_to_br }}
      </span>
    </div>
  {% endif %}

  {% if product.metafields.tvo.polyhenial_count != blank %}
    <div class="flex flex-col items-center justify-start gap-5 pb-[10px] text-center">
      <span class="text-dark-grey uppercase font-sans tracking-[0.15em] text-sm">Polyphenol Count</span>
      <span class="font-serif italic text-grey-50">{{ product.metafields.tvo.polyhenial_count }}</span>
    </div>
  {% endif %}
</div>
