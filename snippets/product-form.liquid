<form class="space-y-6 js-product-form">
  {% comment %} Hidden input for the variant id. Will be updated based on Size selection {% endcomment %}
  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

  {% comment %} Flavor Selector {% endcomment %}
  {% if product.type == 'Olive Oil' %}
    {% assign olive_oils = collections['olive-oils'].products %}
    
    {% comment %} Get GWP data from blocks {% endcomment %}
    {% assign gwp_products_list = null %}
    {% for block in blocks %}
      {% if block.type == 'gwp_message' %}
        {% assign gwp_products_list = block.settings.products_to_show_gwp_on %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% comment %}
      <div class="relative" data-js-flavor-selector>
        <button
          type="button"
          class="rounded-md w-full border border-border text-dark-grey p-[10px] pr-[20px] flex items-center gap-3"
          data-js-flavor-button
        >
          <div class="bg-[#F3F3F3] rounded-md">
            <img
              src="{{ product.featured_image | image_url: width: 200 }}"
              alt="{{ product.title }}"
              class="w-16 h-16 object-contain"
            >
          </div>
          <span class="uppercase font-sans tracking-[0.15em] text-sm">{{ product.title }}</span>
          <div class="ml-auto">
            {% render 'icon-chevron-down' %}
          </div>
        </button>

        <div
          class="absolute z-10 top-full left-0 right-0 bg-white border border-t-0 border-border rounded-md hidden"
          data-js-flavor-dropdown
        >
          {% for olive_oil in olive_oils %}
            {% if olive_oil.title != product.title %}
              <button
                type="button"
                class="w-full p-[14px] flex items-center gap-3 hover:bg-[#fafafa] {% if olive_oil.id == product.id %}bg-grey-50/5{% endif %}"
                data-flavor-option
                data-product-url="{{ olive_oil.url }}"
              >
                <img
                  src="{{ olive_oil.featured_image | image_url: width: 40 }}"
                  alt="{{ olive_oil.title }}"
                  class="w-10 h-10 object-contain"
                >
                <span class="uppercase font-sans tracking-[0.15em] text-sm">{{ olive_oil.title }}</span>
              </button>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endcomment %}

    <div class="mb-8">
      <div class="mb-2 block text-dark-grey italic font-serif">Varietal</div>
      <div class="flex gap-3 overflow-x-auto">
        {% assign olive_oils = collections['olive-oils'].products %}
        {% for olive_oil in olive_oils %}
          {% comment %} Check if this olive oil has GWP {% endcomment %}
          {% assign has_gwp = false %}
          {% if gwp_products_list %}
            {% for gwp_product in gwp_products_list %}
              {% if gwp_product.handle == olive_oil.handle %}
                {% assign has_gwp = true %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
          <div class="relative">
            {% if has_gwp %}
              <div class="absolute -top-2 -right-1 z-20">
                <span class="inline-block bg-picual-red text-white text-[7px] font-semibold px-1 py-0.5 rounded-sm uppercase leading-none whitespace-nowrap">
                  Gift w/ Purchase
                </span>
              </div>
            {% endif %}
            <button
              type="button"
              class="flex-none w-[105px] p-1.5 border rounded-[6px] border-border hover:border-dark-grey transition-colors {% if olive_oil.id == product.id %}border-dark-grey{% else %}border-black/10{% endif %}"
              data-flavor-option
              data-product-url="{{ olive_oil.url }}"
            >
          
              <div class="flex flex-col items-center gap-1.5">
                <div class="bg-[#F3F3F3] p-2 rounded-[6px] w-full flex items-center justify-center aspect-square">
                  <img
                    src="{{ olive_oil.featured_image | image_url: width: auto }}"
                    alt="{{ olive_oil.title }}"
                    width=""
                    height="78"
                    class="w-16 h-16 object-contain"
                  >
                </div>
                <span class="font-sans text-center font-semibold text-[10px] leading-[100%] tracking-[0.15em] uppercase text-neutral-700">
                  {{- olive_oil.title -}}
                </span>
              </div>
            </button>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% comment %} Quantity Selector {% endcomment %}
  <div class="flex justify-between items-center">
    <label for="quantity" class="block text-dark-grey italic font-serif">Quantity</label>
    <div class="flex gap-4">
      {% for i in (1..4) %}
        <div class="flex items-center">
          <input
            type="radio"
            name="quantity"
            id="quantity-{{ i }}"
            value="{{ i }}"
            class="sr-only peer"
            {% if forloop.first %}
              checked
            {% endif %}
          >
          <label
            for="quantity-{{ i }}"
            class="flex items-center justify-center border-b border-transparent hover:border-b-dark-grey peer-checked:border-b-dark-grey cursor-pointer text-grey-50 peer-checked:text-dark-grey"
          >
            {{ i }}
          </label>
        </div>
      {% endfor %}
    </div>
  </div>

  {% comment %} Purchase Options {% endcomment %}
  {% if product.type != 'Gift Card' %}
    <div class="space-y-[0px]">
      {% if product.selling_plan_groups.size > 0 %}
        <label
          for="subscribe"
          class="subscription-main flex items-center justify-between flex-wrap cursor-pointer p-[15px] lg:p-[18px] border border-black/20 rounded-t-[6px]"
        >
          <div class="flex items-start justify-between w-full">
            <div class="flex flex-col">
              <div class="flex items-center space-x-2">
                <input
                  type="radio"
                  name="selling_plan"
                  value="{{ product.selling_plan_groups[0].selling_plans[0].id }}"
                  id="subscribe"
                  checked
                  class="appearance-none size-5 border border-grey-50 rounded-full checked:before:content-[''] checked:before:absolute checked:before:w-[10px] checked:before:h-[10px] checked:before:bg-dark-grey checked:border-dark-grey checked:before:rounded-full checked:before:top-1/2 checked:before:left-1/2 checked:before:-translate-x-1/2 checked:before:-translate-y-1/2 relative cursor-pointer"
                >
                <span class="ml-2 font-serif">Subscribe and save</span>
              </div>
            </div>
            <span class="flex items-center gap-1 font-serif">
              {{ product.price | times: 0.9 | money }}
              <span
                class="rounded-[5px] px-[5px] py-[3px] bg-[#eaf4d1] font-medium text-[12px] leading-[100%]"
                style="
                  color: white;
                  background-color: {{ product.metafields.tvo.label_color | default: '#C53E12' }};
                "
              >
                Save 10%
              </span>
            </span>
          </div>
          <div
            class="subscription-option relative w-auto flex items-center gap-[10px] pt-3 pl-7"
            data-js-selling-plan-selector-container
          >
            <div class="text-[15px] leading-[100%]">Deliver every</div>
            <div class="relative">
              <button
                type="button"
                class="rounded-md border border-border p-[8px] pr-[8px] flex items-center gap-3"
                data-js-selling-plan-button
              >
                <span class="font-serif text-[15px] leading-[100%]" data-js-selling-plan-text>
                  {% assign plan_name = product.selling_plan_groups[0].selling_plans[0].name %}
                  {% if plan_name contains 'every 6 months' %}
                    180 days
                  {% elsif plan_name contains 'every 4 months' %}
                    120 days
                  {% elsif plan_name contains 'every 3 months' or plan_name contains 'quarterly' %}
                    90 days
                  {% elsif plan_name contains 'every 2 months' %}
                    60 days
                  {% elsif plan_name contains 'month' %}
                    30 days
                  {% elsif plan_name contains '2 weeks' or plan_name contains 'bi-weekly' %}
                    14 days
                  {% elsif plan_name contains 'week' %}
                    7 days
                  {% else %}
                    {{ plan_name }}
                  {% endif %}
                </span>
                <div class="ml-auto dropdown-down-arrow">
                  {% render 'icon-chevron-down' %}
                </div>
              </button>

              <div
                class="absolute z-10 top-full left-0 right-0 bg-white border border-t-0 border-border rounded-md hidden"
                data-js-selling-plan-dropdown
              >
                {% for selling_plan in product.selling_plan_groups[0].selling_plans %}
                  <button
                    type="button"
                    class="w-full p-[8px] flex items-center gap-3 hover:bg-[#fafafa]"
                    data-selling-plan-option
                    data-selling-plan-id="{{ selling_plan.id }}"
                  >
                    <span class="font-serif text-[15px] leading-[100%]">
                      {% if selling_plan.name contains 'every 6 months' %}
                        180 days
                      {% elsif selling_plan.name contains 'every 4 months' %}
                        120 days
                      {% elsif selling_plan.name contains 'every 3 months'
                        or selling_plan.name contains 'quarterly'
                      %}
                        90 days
                      {% elsif selling_plan.name contains 'every 2 months' %}
                        60 days
                      {% elsif selling_plan.name contains 'month' %}
                        30 days
                      {% elsif selling_plan.name contains '2 weeks' or selling_plan.name contains 'bi-weekly' %}
                        14 days
                      {% elsif selling_plan.name contains 'week' %}
                        7 days
                      {% else %}
                        {{ selling_plan.name }}
                      {% endif %}
                    </span>
                  </button>
                {% endfor %}
              </div>
              <select
                data-js-selling-plan-selector
                name="selling_plan"
                class="hidden"
              >
                {% for selling_plan in product.selling_plan_groups[0].selling_plans %}
                  <option value="{{ selling_plan.id }}">
                    {{ selling_plan.name }}
                  </option>
                {% endfor %}
              </select>
            </div>
          </div>
        </label>
      {% endif %}
      <label
        for="one-time"
        class="flex items-center justify-between cursor-pointer p-[15px] lg:p-[18px] border border-black/20 rounded-b-[6px] {% if product.selling_plan_groups.size > 0 %} border-t-0{% endif %}"
      >
        <div class="flex items-center space-x-2">
          <input
            type="radio"
            name="selling_plan"
            value=""
            id="one-time"
            {% if product.selling_plan_groups.size == 0 %}
              checked
            {% endif %}
            class="appearance-none size-5 border border-grey-50 rounded-full checked:before:content-[''] checked:before:absolute checked:before:w-[10px] checked:before:h-[10px] checked:before:bg-dark-grey checked:border-dark-grey checked:before:rounded-full checked:before:top-1/2 checked:before:left-1/2 checked:before:-translate-x-1/2 checked:before:-translate-y-1/2 relative cursor-pointer"
          >
          <span class="ml-2 font-serif">One-time purchase</span>
        </div>
        <span class="flex items-center gap-1">
          {{ product.price | money }}
          {% if product.compare_at_price > product.price %}
            <span
              class="rounded-[5px] px-[5px] py-[3px] bg-[#eaf4d1] font-medium text-[12px] leading-[100%]"
              style="
                color: white;
                background-color: {{ product.metafields.tvo.label_color | default: '#C53E12' }};
              "
            >
              Save
              {{
                product.compare_at_price
                | minus: product.price
                | times: 100.0
                | divided_by: product.compare_at_price
                | round
              -}}
              %
            </span>
          {% endif %}
        </span>
      </label>
    </div>
  {% endif %}

  {% comment %} Gift Card Denominations {% endcomment %}
  {% if product.gift_card? and product.variants.size > 1 %}
    <div class="mt-5 space-y-5 border-b border-border pb-5 flex items-start justify-between">
      <p class="block text-dark-grey italic font-serif">Select an amount:</p>
      <div class="space-y-5 flex items-start justify-center flex-col">
        {% for variant in product.variants %}
          <label
            for="variant-{{ variant.id }}"
            class="flex items-center justify-between cursor-pointer w-full"
          >
            <div class="flex items-center space-x-2 justify-between w-full">
              <input
                type="radio"
                name="id"
                value="{{ variant.id }}"
                id="variant-{{ variant.id }}"
                {% if forloop.first %}
                  checked
                {% endif %}
                class="appearance-none size-5 border border-grey-50 rounded-full checked:before:content-[''] checked:before:absolute checked:before:w-[10px] checked:before:h-[10px] checked:before:bg-dark-grey checked:border-dark-grey checked:before:rounded-full checked:before:top-1/2 checked:before:left-1/2 checked:before:-translate-x-1/2 checked:before:-translate-y-1/2 relative cursor-pointer"
              >
              <span class="font-serif">{{ variant.price | money }}</span>
            </div>
          </label>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% comment %} Frequency Selector for Selling Plans {% endcomment %}
  {% if product.selling_plan_groups.size > 0 %}
  {% endif %}

  {% comment %} Size Selector {% endcomment %}
  {% if product.options contains 'Size' %}
    {% assign size_option = product.options_with_values | where: 'name', 'Size' | first %}
    <div class="relative" data-js-size-selector-container>
      <select
        data-js-size-selector
        name="size"
        class="w-full border border-border rounded-sm text-dark-grey uppercase font-sans tracking-[0.15em] text-sm appearance-none p-[14px] cursor-pointer"
      >
        {% for size in size_option.values %}
          <option value="{{ size }}">
            {{ size }}
          </option>
        {% endfor %}
      </select>
      <div class="absolute right-[14px] top-0 h-full flex items-center justify-center">
        {% render 'icon-arrow-down' %}
      </div>
    </div>
  {% endif %}

  {% comment %} Add to Cart Button {% endcomment %}
  <button
    type="submit"
    name="add"
    class="w-full bg-dark-grey text-white uppercase font-sans tracking-[0.15em] text-sm p-5 rounded-[6px]"
    {% unless product.available %}
      disabled
    {% endunless %}
    data-ph-capture-attribute-product-name="{{ product.title }}"
    data-ph-capture-attribute-product-price="{{ product.price | divided_by: 100 }}"
  >
    {% if product.available %}
      Buy Now
    {% else %}
      Sold Out
    {% endif %}
  </button>
  <p class="text-center mt-0 my-0" style="margin-top: 0;">(Shipping Not Included)</p>

  {% for block in blocks %}
    {% if block.type == 'gwp_message' %}
      {% render 'product-gift-with-purchase-message',
        current_product: product,
        products_to_show_gwp_on: block.settings.products_to_show_gwp_on,
        upsell_product: block.settings.upsell_product,
        upsell_message: block.settings.upsell_message
      %}
    {% endif %}
  {% endfor %}
</form>

<style>
  .dropdown-down-arrow svg {
    width: 10px;
    height: auto;
  }
  .dropdown-down-arrow svg path {
    stroke: #7f7f7f;
  }
  .subscription-main:has(.subscription-option.hidden) {
    border-color: rgba(0, 0, 0, 0.2);
    border-bottom: none;
  }
  .subscription-main:not(:has(.subscription-option.hidden)) {
    border-color: rgba(0, 0, 0, 0.5);
  }
  .subscription-main:has(.subscription-option.hidden) + label {
    border-top: 1px solid;
    border-color: rgba(0, 0, 0, 0.5);
  }
  .product-faq-item + .product-faq-item {
    margin-top: 0 !important;
  }
</style>

<script>
  function toggleproductFaq(element) {
    const answer = element.nextElementSibling;
    const icon = element.querySelector('span');

    document.querySelectorAll('.product-faq-answer').forEach((el) => {
      if (el !== answer) {
        el.style.maxHeight = null;
        el.previousElementSibling.querySelector('span').style.transform = 'rotate(0deg)';
      }
    });

    if (answer.style.maxHeight) {
      answer.style.maxHeight = null;
      icon.style.transform = 'rotate(0deg)';
    } else {
      answer.style.maxHeight = answer.scrollHeight + 'px';
      icon.style.transform = 'rotate(45deg)';
    }
  }
</script>

<script type="application/json" id="variants-json">
  {{ product.variants | json }}
</script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Get all product variants for lookup based on the selected Size.
    const variants = JSON.parse(document.getElementById('variants-json').textContent);
    const form = document.querySelector('.js-product-form');
    const sellingPlanContainer = document.querySelector('[data-js-selling-plan-selector-container]');
    const oneTimeRadio = document.getElementById('one-time');
    const subscribeRadio = document.getElementById('subscribe');
    const sizeSelector = document.querySelector('[data-js-size-selector]');
    const denominationRadios = document.querySelectorAll('input[name="id"][type="radio"]');

    // Flavor selector elements
    const flavorSelector = document.querySelector('[data-js-flavor-selector]');
    const flavorButton = document.querySelector('[data-js-flavor-button]');
    const flavorDropdown = document.querySelector('[data-js-flavor-dropdown]');
    const flavorOptions = document.querySelectorAll('[data-flavor-option]');

    // Selling plan selector elements
    const sellingPlanButton = document.querySelector('[data-js-selling-plan-button]');
    const sellingPlanDropdown = document.querySelector('[data-js-selling-plan-dropdown]');
    const sellingPlanOptions = document.querySelectorAll('[data-selling-plan-option]');
    const sellingPlanText = document.querySelector('[data-js-selling-plan-text]');
    const sellingPlanSelect = document.querySelector('[data-js-selling-plan-selector]');

    // Toggle flavor dropdown
    flavorButton?.addEventListener('click', () => {
      flavorDropdown?.classList.toggle('hidden');
    });

    // Toggle selling plan dropdown
    sellingPlanButton?.addEventListener('click', () => {
      sellingPlanDropdown?.classList.toggle('hidden');
    });

    // Close dropdowns when clicking outside
    document.addEventListener('click', (e) => {
      if (!flavorSelector?.contains(e.target)) {
        flavorDropdown?.classList.add('hidden');
      }
      if (!sellingPlanContainer?.contains(e.target)) {
        sellingPlanDropdown?.classList.add('hidden');
      }
    });

    // Handle flavor option clicks
    flavorOptions?.forEach((option) => {
      option.addEventListener('click', () => {
        const productUrl = option.dataset.productUrl;
        if (productUrl) {
          window.location.href = productUrl;
        }
      });
    });

    // Handle selling plan option clicks
    sellingPlanOptions?.forEach((option) => {
      option.addEventListener('click', () => {
        const planId = option.dataset.sellingPlanId;
        const planName = option.querySelector('span').textContent;
        if (sellingPlanSelect && planId) {
          sellingPlanSelect.value = planId;
        }
        if (sellingPlanText && planName) {
          sellingPlanText.textContent = planName.trim();
        }
        sellingPlanDropdown?.classList.add('hidden');
      });
    });

    // The hidden input that holds the variant id.
    const variantInput = form.querySelector('input[name="id"]');

    // Handle radio changes for selling plans.
    if (oneTimeRadio) {
      oneTimeRadio.addEventListener('change', () => {
        if (sellingPlanContainer) {
          sellingPlanContainer.classList.add('hidden');
        }
      });
    }

    if (subscribeRadio) {
      subscribeRadio.addEventListener('change', () => {
        if (sellingPlanContainer) {
          sellingPlanContainer.classList.remove('hidden');
        }
      });
    }

    // Handle changes to the Size selector.
    if (sizeSelector) {
      sizeSelector.addEventListener('change', (e) => {
        const selectedSize = e.target.value;
        // Find the variant where the Size (option1) matches the selected value.
        const selectedVariant = variants.find((variant) => variant.option1 === selectedSize);
        if (selectedVariant) {
          variantInput.value = selectedVariant.id;
        }
      });
      // Trigger the change event on load to update the variant id based on default selection.
      sizeSelector.dispatchEvent(new Event('change'));
    }

    // Handle changes to gift card denomination radios
    if (denominationRadios.length > 0) {
      denominationRadios.forEach((radio) => {
        radio.addEventListener('change', (e) => {
          variantInput.value = e.target.value;
        });
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      // Ensure only one selling_plan value is submitted:
      if (subscribeRadio && subscribeRadio.checked) {
        const planSelector = document.querySelector('[data-js-selling-plan-selector]');
        if (planSelector) {
          formData.set('selling_plan', planSelector.value);
        }
      } else if (oneTimeRadio?.checked || !oneTimeRadio) {
        formData.delete('selling_plan');
      }

      try {
        // Add main product to cart
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          body: formData,
        });
        const data = await response.json();

        // Check if there's a GWP product to add
        const gwpProductId = document.getElementById('gwp-product-id');
        const gwpProductTitle = document.getElementById('gwp-product-title');
        
        if (gwpProductId && gwpProductId.value) {
          try {
            // Add GWP product to cart
            const gwpFormData = new FormData();
            gwpFormData.append('id', gwpProductId.value);
            gwpFormData.append('quantity', '1');
            
            const gwpResponse = await fetch('/cart/add.js', {
              method: 'POST',
              body: gwpFormData,
            });
            
            if (gwpResponse.ok) {
              console.log(`GWP product "${gwpProductTitle?.value || 'Gift'}" added to cart`);
            } else {
              console.warn('Failed to add GWP product to cart');
            }
          } catch (gwpError) {
            console.warn('Error adding GWP product to cart:', gwpError);
          }
        }

        document.dispatchEvent(new Event('product:added'));
      } catch (error) {
        console.error('Error adding to cart:', error);
      }
    });
  });
</script>
